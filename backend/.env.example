# Display branding
APP_NAME=Colloqui CRM

# development | production
ENVIRONMENT=development

# Postgres for real deployments; sqlite works for quick local runs:
#   sqlite+aiosqlite:///./dev.db
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# 32+ random chars in production (openssl rand -hex 32)
SECRET_KEY=dev-secret-change-me

ALLOWED_ORIGINS=http://localhost:5173

SESSION_TTL_DAYS=30

# iOS companion-app push, delivered through the shared push relay (the relay
# holds the Apple credentials; this key is scoped to the CRM's bundle id).
# Leave unset to disable push — task reminders then go to Colloqui chat only.
#PUSH_RELAY_URL=https://push.example.com
#PUSH_RELAY_API_KEY=pk_...
#APNS_TOPIC=com.jworthington.colloquicrm
